{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://side-brain.local/team/schemas/paper-card.schema.json",
  "title": "Team Side-Brain Paper Card",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "paper_id",
    "research_question",
    "method",
    "data",
    "findings",
    "innovation",
    "limitations",
    "relevance",
    "possible_use",
    "confidence",
    "source_trace",
    "ai_model_used",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "paper_id": { "type": "string", "minLength": 1 },
    "research_question": { "type": "string" },
    "method": { "type": "string" },
    "data": { "type": "string" },
    "findings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "innovation": { "type": "string" },
    "limitations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "relevance": { "type": "string" },
    "possible_use": {
      "type": "array",
      "items": { "type": "string" }
    },
    "confidence": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "source_trace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["paper_id", "processor", "prompt_version", "processed_at"],
      "properties": {
        "paper_id": { "type": "string" },
        "source_document": { "type": "string" },
        "text_excerpt_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "processor": { "type": "string" },
        "ai_provider": { "type": "string" },
        "ai_model": { "type": "string" },
        "prompt_version": { "type": "string" },
        "processed_at": { "type": "string", "format": "date-time" }
      }
    },
    "ai_model_used": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}
