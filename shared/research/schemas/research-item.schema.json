{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://side-brain.local/shared/research/schemas/research-item.schema.json",
  "title": "Side-Brain Research Item",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "item_type",
    "title",
    "authors",
    "abstract",
    "year",
    "venue",
    "identifiers",
    "url",
    "object_key",
    "source_ids",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "item_type": {
      "type": "string",
      "enum": ["paper", "article", "report", "webpage", "dataset", "book", "code", "note", "other"]
    },
    "title": { "type": "string", "minLength": 1 },
    "authors": {
      "type": "array",
      "items": { "type": "string" }
    },
    "abstract": { "type": "string" },
    "year": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "venue": { "type": ["string", "null"] },
    "identifiers": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "properties": {
        "doi": { "type": "string" },
        "arxiv_id": { "type": "string" },
        "zotero_key": { "type": "string" },
        "isbn": { "type": "string" }
      }
    },
    "url": { "type": ["string", "null"] },
    "object_key": { "type": ["string", "null"] },
    "source_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}
