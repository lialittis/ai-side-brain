# Personal memory and generated local state.
# Only placeholder files are allowed inside memory/ so the public repo can show structure.
memory/**
!memory/**/
!memory/**/.gitkeep

indexes/**
!indexes/
!indexes/.gitkeep
!indexes/README.md

# Implementation state
CODEx.md

# Local agent/tool state
.agents/**
.codex/**
!.agents/
!.codex/
!.agents/.gitkeep
!.codex/.gitkeep

# Inbox, logs, archives, backups, and exports
**/00_Inbox/**
**/06_Logs/**
**/90_Archive/**
**/backup*/**
**/backups/**
**/exports/**
*.bak
*.backup
*.orig
*.tmp
*.log
*.zip
*.tar
*.tar.gz
*.tgz
*.7z

# Re-allow memory placeholders after the broad private-content rules above.
!memory/**/
!memory/**/.gitkeep

