# Copy to .env for local-only API configuration.
# .env is ignored by Git.

OPENAI_API_KEY=
SIDE_BRAIN_AI_PROVIDER=openai
SIDE_BRAIN_OPENAI_MODEL=gpt-5.5

GLM_API_KEY=
SIDE_BRAIN_GLM_MODEL=glm-5.2
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions

DEEPSEEK_API_KEY=
SIDE_BRAIN_DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

SIDE_BRAIN_CAPTURE_TOKEN=
SIDE_BRAIN_N8N_WEBHOOK_URL=http://your-tailscale-host:5678/webhook/side-brain-capture

# Future Cloudflare capture layer.
# These are not required by the current local capture script.
SIDE_BRAIN_CAPTURE_API_URL=https://capture.example.com
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_QUEUE_NAME=side-brain-captures
