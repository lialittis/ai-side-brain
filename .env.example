# Copy to .env for local-only API configuration.
# .env is ignored by Git.

OPENAI_API_KEY=
SIDE_BRAIN_AI_PROVIDER=openai
SIDE_BRAIN_OPENAI_MODEL=gpt-5.5

GLM_API_KEY=
SIDE_BRAIN_GLM_MODEL=glm-5.2
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions

DEEPSEEK_API_KEY=
SIDE_BRAIN_DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

OPENROUTER_API_KEY=
SIDE_BRAIN_OPENROUTER_MODEL=~openai/gpt-latest
SIDE_BRAIN_OPENROUTER_PDF_ENGINE=cloudflare-ai

SIDE_BRAIN_CAPTURE_TOKEN=
SIDE_BRAIN_N8N_WEBHOOK_URL=http://your-tailscale-host:5678/webhook/side-brain-capture

SIDE_BRAIN_LOCAL_INGEST_TOKEN=
SIDE_BRAIN_LOCAL_INGEST_URL=http://127.0.0.1:8765/ingest/capture
SIDE_BRAIN_LOCAL_INGEST_HOST=127.0.0.1
SIDE_BRAIN_LOCAL_INGEST_PORT=8765

# Future Cloudflare capture layer.
# These are not required by the current local capture script.
# The API URL is public configuration. The bearer token above is the secret.
SIDE_BRAIN_CAPTURE_API_URL=https://capture.tianchiyu.me/capture
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_QUEUE_NAME=side-brain-captures
