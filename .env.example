# Copy to .env for local-only API configuration.
# .env is ignored by Git.

OPENAI_API_KEY=
SIDE_BRAIN_AI_PROVIDER=openai
SIDE_BRAIN_OPENAI_MODEL=gpt-5.5

GLM_API_KEY=
SIDE_BRAIN_GLM_MODEL=glm-5.2
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions

DEEPSEEK_API_KEY=
SIDE_BRAIN_DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

OPENROUTER_API_KEY=
SIDE_BRAIN_OPENROUTER_MODEL=~openai/gpt-latest
SIDE_BRAIN_OPENROUTER_PDF_ENGINE=cloudflare-ai

SIDE_BRAIN_CAPTURE_TOKEN=
SIDE_BRAIN_N8N_WEBHOOK_URL=http://your-tailscale-host:5678/webhook/side-brain-capture

SIDE_BRAIN_LOCAL_INGEST_TOKEN=
SIDE_BRAIN_LOCAL_INGEST_URL=http://127.0.0.1:8765/ingest/capture
SIDE_BRAIN_LOCAL_INGEST_HOST=127.0.0.1
SIDE_BRAIN_LOCAL_INGEST_PORT=8765

# Future Cloudflare capture layer.
# These are not required by the current local capture script.
# The API URL is public configuration. The bearer token above is the secret.
SIDE_BRAIN_CAPTURE_API_URL=https://capture.tianchiyu.me/capture
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_QUEUE_NAME=side-brain-captures

# Literature Radar scheduled jobs.
# Team and Personal scripts source this file before collection/status/brief runs.
# Keep API keys private; do not commit a filled .env.
SEMANTIC_SCHOLAR_API_KEY=
RADAR_SOURCE_CONTACT_EMAIL=
# PERSONAL_RADAR_SOURCE_CONTACT_EMAIL=
OPENALEX_MAILTO=
CROSSREF_MAILTO=
UNPAYWALL_EMAIL=

# Team Literature Radar: use saved /radar defaults, or override them here.
# RADAR_USE_SAVED_DEFAULTS=1
# RADAR_SOURCE_PRESET=team_security_daily
# Shared OpenReview invitation fallback for Team and Personal jobs.
# OPENREVIEW_INVITATIONS=
# RADAR_OUTPUT_DIR=team/logs
# RADAR_QUEUE_LIMIT=20
# RADAR_CYCLE_IMPORT_QUEUE=0
# RADAR_IMPORT_QUEUE_MIN_SCORE=35
# RADAR_FRESHNESS_MAX_AGE_HOURS=36
# RADAR_CACHE_PDFS=0
# RADAR_PDF_CACHE_DIR=team/data/literature-radar-pdfs
# Replace official.example URLs with stable official accepted-paper pages.
# RADAR_OFFICIAL_ACCEPTED_PAGES=$'ieee_sp | IEEE Symposium on Security and Privacy 2026 | 2026 | https://official.example/ieee-sp-2026-accepted-papers\nccs | ACM CCS 2026 | 2026 | https://official.example/ccs-2026-accepted-papers'

